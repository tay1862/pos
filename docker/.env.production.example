# -----------------------------------------------------------------------------
# KINSAEP POS - Production Environment Variables Example
# -----------------------------------------------------------------------------

# --- General ---
NODE_ENV=production
PORT=3000
APP_SECRET=your_very_long_random_app_secret_here
CORS_ORIGIN=https://admin.yourdomain.com,https://pos.yourdomain.com

# --- Database (PostgreSQL) ---
# Used by the API container
DATABASE_URL=postgresql://pos_user:pos_secure_password@postgres:5432/kinsaep_pos?schema=public

# Used by the Postgres container
DB_USER=pos_user
DB_PASSWORD=pos_secure_password
DB_NAME=kinsaep_pos

# --- Cache & Queue (Redis) ---
# Format: redis://[:password]@host:port
REDIS_URL=redis://:redis_secure_password@redis:6379
REDIS_PASSWORD=redis_secure_password

# --- Security ---
# Secret for JWT signing
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# --- External Services (Future) ---
# CLOUDINARY_URL=...
# SENTRY_DSN=...

# --- Web Admin (Next.js) ---
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
