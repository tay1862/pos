// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Store & Auth
// ──────────────────────────────────────────

model Store {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  email       String?
  logo        String?
  taxId       String?  @map("tax_id")
  taxRate     Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  currency    String   @default("THB")
  receiptHeader String? @map("receipt_header")
  receiptFooter String? @map("receipt_footer")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       StoreUser[]
  staff       Staff[]
  categories  Category[]
  products    Product[]
  inventoryLots InventoryLot[]
  orders      Order[]
  tickets     Ticket[]
  customers   Customer[]
  settings    StoreSetting[]
  syncEvents  SyncEvent[]

  @@map("stores")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  passwordHash String   @map("password_hash")
  name        String
  phone       String?
  role        UserRole @default(OWNER)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  stores      StoreUser[]

  @@map("users")
}

model StoreUser {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  storeId String @map("store_id")
  role    UserRole @default(OWNER)

  user    User  @relation(fields: [userId], references: [id])
  store   Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@map("store_users")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  STAFF
}

model Staff {
  id          String   @id @default(cuid())
  storeId     String   @map("store_id")
  name        String
  pinHash     String   @map("pin_hash") // hashed 4-6 digit PIN
  role        UserRole @default(CASHIER)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store       Store    @relation(fields: [storeId], references: [id])
  orders      Order[]
  tickets     Ticket[]
  activityLogs ActivityLog[]

  @@map("staff")
}

// ──────────────────────────────────────────
// Products & Categories
// ──────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  storeId     String   @map("store_id")
  name        String
  nameLao     String?  @map("name_lao")
  icon        String?
  color       String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  store       Store    @relation(fields: [storeId], references: [id])
  products    Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  storeId     String   @map("store_id")
  categoryId  String?  @map("category_id")
  name        String
  nameLao     String?  @map("name_lao")
  description String?
  sku         String?
  barcode     String?
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal  @default(0) @db.Decimal(12, 2)
  imageUrl    String?  @map("image_url")
  trackStock  Boolean  @default(true) @map("track_stock")
  stockQuantity Int    @default(0) @map("stock_quantity")
  lowStockThreshold Int @default(5) @map("low_stock_threshold")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  store       Store    @relation(fields: [storeId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
  inventoryLots InventoryLot[]
  orderItems  OrderItem[]
  ticketItems TicketItem[]

  @@index([storeId, barcode])
  @@index([storeId, categoryId])
  @@map("products")
}

// ──────────────────────────────────────────
// Inventory FIFO
// ──────────────────────────────────────────

model InventoryLot {
  id            String   @id @default(cuid())
  storeId       String   @map("store_id")
  productId     String   @map("product_id")
  lotNumber     String?  @map("lot_number")
  quantity      Int      // initial quantity received
  remaining     Int      // current remaining (FIFO deduction)
  costPerUnit   Decimal  @map("cost_per_unit") @db.Decimal(12, 2)
  expiryDate    DateTime? @map("expiry_date")
  receivedAt    DateTime @default(now()) @map("received_at")
  createdAt     DateTime @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  store         Store    @relation(fields: [storeId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])
  stockMovements StockMovement[]

  @@index([storeId, productId, receivedAt])
  @@map("inventory_lots")
}

model StockMovement {
  id            String        @id @default(cuid())
  lotId         String        @map("lot_id")
  type          MovementType
  quantity      Int           // positive = in, negative = out
  reference     String?       // order_id or reason
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")

  lot           InventoryLot  @relation(fields: [lotId], references: [id])

  @@map("stock_movements")
}

enum MovementType {
  RECEIVE    // รับสินค้าเข้า
  SALE       // ขายสินค้า
  RETURN     // คืนสินค้า
  ADJUSTMENT // ปรับสต็อก
  TRANSFER   // โอนสาขา (V3)
}

// ──────────────────────────────────────────
// Orders & Tickets (Open Bills)
// ──────────────────────────────────────────

model Ticket {
  id          String       @id @default(cuid())
  storeId     String       @map("store_id")
  staffId     String?      @map("staff_id")
  customerId  String?      @map("customer_id")
  name        String?      // ticket name or table number
  status      TicketStatus @default(OPEN)
  note        String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  store       Store        @relation(fields: [storeId], references: [id])
  staff       Staff?       @relation(fields: [staffId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  items       TicketItem[]

  @@index([storeId, status])
  @@map("tickets")
}

enum TicketStatus {
  OPEN
  PAID
  COMPLETED
  CANCELLED
}

model TicketItem {
  id          String   @id @default(cuid())
  ticketId    String   @map("ticket_id")
  productId   String   @map("product_id")
  quantity    Int
  price       Decimal  @db.Decimal(12, 2)
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("ticket_items")
}

model Order {
  id            String       @id @default(cuid())
  storeId       String       @map("store_id")
  deviceId      String?      @map("device_id")
  staffId       String?      @map("staff_id")
  customerId    String?      @map("customer_id")
  ticketId      String?      @map("ticket_id")
  orderNumber   String       @map("order_number")
  subtotal      Decimal      @db.Decimal(12, 2)
  discountType  DiscountType? @map("discount_type")
  discountValue Decimal      @default(0) @map("discount_value") @db.Decimal(12, 2)
  discountTotal Decimal      @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal      Decimal      @default(0) @map("tax_total") @db.Decimal(12, 2)
  total         Decimal      @db.Decimal(12, 2)
  status        OrderStatus  @default(PAID)
  note          String?
  localId       String?      @map("local_id") // SQLite ID for sync
  deletedAt     DateTime?    @map("deleted_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  store         Store        @relation(fields: [storeId], references: [id])
  staff         Staff?       @relation(fields: [staffId], references: [id])
  customer      Customer?    @relation(fields: [customerId], references: [id])
  ticket        Ticket?      @relation(fields: [ticketId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@index([storeId, createdAt])
  @@index([storeId, orderNumber])
  @@map("orders")
}

enum OrderStatus {
  COMPLETED
  PAID
  REFUNDED
  VOIDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String   @map("order_id")
  productId     String   @map("product_id")
  name          String
  quantity      Int
  price         Decimal  @db.Decimal(12, 2)
  total         Decimal  @db.Decimal(12, 2)
  cost          Decimal  @default(0) @db.Decimal(12, 2) // cost at time of sale (FIFO)
  note          String?
  discountType  DiscountType? @map("discount_type")
  discountValue Decimal  @default(0) @map("discount_value") @db.Decimal(12, 2)
  discountTotal Decimal  @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal      Decimal  @default(0) @map("tax_total") @db.Decimal(12, 2)

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ──────────────────────────────────────────
// Payment
// ──────────────────────────────────────────

model Payment {
  id             String        @id @default(cuid())
  orderId        String        @map("order_id")
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 2)
  receivedAmount Decimal       @default(0) @map("received_amount") @db.Decimal(12, 2)
  changeAmount   Decimal       @default(0) @map("change_amount") @db.Decimal(12, 2)
  referenceNote  String?       @map("reference_note")
  note           String?
  status         PaymentStatus @default(COMPLETED)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentMethod {
  CASH
  TRANSFER
  OTHER
}

enum PaymentStatus {
  COMPLETED
  FAILED
  REFUNDED
}

// ──────────────────────────────────────────
// Sync Events (Idempotency)
// ──────────────────────────────────────────

model SyncEvent {
  id             String   @id @default(cuid())
  storeId        String   @map("store_id")
  deviceId       String?  @map("device_id")
  idempotencyKey String   @unique @map("idempotency_key")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  status         String   @default("COMPLETED")
  createdAt      DateTime @default(now()) @map("created_at")

  store          Store    @relation(fields: [storeId], references: [id])

  @@index([storeId, idempotencyKey])
  @@map("sync_events")
}

// ──────────────────────────────────────────
// Customers
// ──────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  storeId     String   @map("store_id")
  name        String
  phone       String?
  email       String?
  points      Int      @default(0)
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store       Store    @relation(fields: [storeId], references: [id])
  orders      Order[]
  tickets     Ticket[]

  @@index([storeId, phone])
  @@map("customers")
}

// ──────────────────────────────────────────
// Settings & Logs
// ──────────────────────────────────────────

model StoreSetting {
  id       String @id @default(cuid())
  storeId  String @map("store_id")
  key      String
  value    String

  store    Store  @relation(fields: [storeId], references: [id])

  @@unique([storeId, key])
  @@map("store_settings")
}

model ActivityLog {
  id        String   @id @default(cuid())
  staffId   String   @map("staff_id")
  action    String
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  staff     Staff    @relation(fields: [staffId], references: [id])

  @@map("activity_logs")
}

// ──────────────────────────────────────────
// Sync Queue (tracking offline changes)
// ──────────────────────────────────────────

model SyncQueue {
  id          String     @id @default(cuid())
  storeId     String     @map("store_id")
  entityType  String     @map("entity_type") // "order", "ticket", "customer", etc.
  entityId    String     @map("entity_id")
  action      SyncAction
  payload     Json
  status      SyncStatus @default(PENDING)
  retryCount  Int        @default(0) @map("retry_count")
  error       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  syncedAt    DateTime?  @map("synced_at")

  @@index([storeId, status])
  @@map("sync_queue")
}

enum SyncAction {
  CREATE
  UPDATE
  DELETE
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}
